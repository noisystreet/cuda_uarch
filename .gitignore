# ─── Build ───────────────────────────────────────────────────────────────────
build/
cmake-build-*/
out/

# ─── CMake generated ───────────────────────────────────────────────────────
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
/Makefile               # CMake generates Makefile in build/, ignore all
!/Makefile              # except our root convenience Makefile
CTestTestfile.cmake

# ─── Compiled binaries / libraries ──────────────────────────────────────────
*.o
*.obj
*.cu.o
*.a
*.lib
*.so
*.dylib
*.exe
*.out

# ─── IDE / Editor ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.orig

# ─── Clang / LSP ────────────────────────────────────────────────────────────
.clangd/
compile_commands.json

# ─── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# ─── Data / results (keep directory, ignore generated content) ──────────────
data/results/*
!data/results/.gitkeep
reports/figures/*
!reports/figures/.gitkeep

# ─── Environment / credentials (just in case) ───────────────────────────────
.env
*.env.local
*.pem
